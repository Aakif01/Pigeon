<% if(success && success.length){ %>
<div class="alert alert-success col-md-6 offset-md-3 mt-2 alert-dismissible" role="alert">
  <%= success %>
  <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
</div>
<% } %>

<% if(error && error.length){ %>
<div class="alert alert-danger col-md-6 offset-md-3 mt-2 alert-dismissible" role="alert">
  <%= error %>
  <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
</div>
<% } %>
 