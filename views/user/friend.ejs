<% layout("layouts/boiler") %>

<% style = `
<link rel="stylesheet" href="/css/friend.css">
` %>
      <div class="head">
      <a href="/pigeon"><i class="fa-solid fa-arrow-left"></i></a><p>New contact</p>
    </div>
  <div class="main">
    <form method="POST" action="/pigeon/new">
      <div>
      <label for="firstName"><i class="fa-solid fa-user"></i></label>
      <input type="text" name="firstName" class="input" id="fistName" placeholder="First name">
      </div>
      <div>

      <input type="text" name="lastName" class="input" id="lastName" placeholder="Last name">
      </div>
      <div>
        <label for="phone"><i class="fa-solid fa-phone"></i></label>
        <input type="text" name="phone" pattern="[0-9]{10}" placeholder="Phone" id="phone" class="input" required>
      </div>
      <button class="save-user">Save</button>
    </form>
  </div>
